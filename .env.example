# Used by `docker compose build` (mounted as a build secret). Compose also reads this file for ${VAR} substitution.
GEMINI_API_KEY=

# If you keep the API key only in `.env.local` (e.g. for Vite) and not in `.env`, uncomment:
# GEMINI_API_KEY_FILE=.env.local

# Portainer (docker-compose.portainer.yml): add stack environment variables, e.g.
#   GEMINI_API_KEY=your-key-here
#   WEB_PORT=3000
# After deploy, verify: open /runtime-config.js — GEMINI_API_KEY should not be empty.

WEB_PORT=
