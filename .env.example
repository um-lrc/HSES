# Used by `docker compose build` (mounted as a build secret). Compose also reads this file for ${VAR} substitution.
GEMINI_API_KEY=

# If you keep the API key only in `.env.local` (e.g. for Vite) and not in `.env`, uncomment:
# GEMINI_API_KEY_FILE=.env.local

# Portainer (docker-compose.portainer.yml): add stack environment variables, e.g.
#   GEMINI_API_KEY=your-key-here
#   IMAGE_TAG=latest
#   WEB_PORT=3000
# After deploy, verify the API key (use your app's base URL if behind a path prefix):
#   View page source → search for "hses-runtime-config" (inline script in <head>)
#   Or open: https://your-host<optional-path>/runtime-config.js
# If /runtime-config.js is 404, you are likely on an old image or the wrong URL path.

WEB_PORT=
